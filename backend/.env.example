APP_NAME=AddisTask API
APP_ENV=local

# Local development database.
# In production, set APP_ENV=production and use the hosted PostgreSQL URL.
DATABASE_URL=postgresql+psycopg2://postgres:123456@localhost:5432/addistask

# Local development only. Production must use a unique secret with at least 32 characters.
JWT_SECRET=change-this-secret
JWT_ALG=HS256
JWT_EXPIRES_MIN=60

# Comma-separated frontend origins allowed by CORS.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000
